rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PREPSTACK SECURITY RULES - PROTOTYPING MODE
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a closed, authenticated-only learning system. It prioritizes strict 
     * authorization (who can access what) while maintaining flexible data structures to support 
     * rapid feature iteration.
     *
     * DATA STRUCTURE:
     * - User-specific data is organized under /users/{userId} to enable simple path-based ownership.
     * - Global content (Courses, Modules, Lessons, Tests) is stored in top-level collections.
     * - Administrative privileges are determined by the /roles_admin collection.
     *
     * KEY SECURITY DECISIONS:
     * - AUTH-ONLY ACCESS: All learning content requires an authenticated session (no visitor access).
     * - OWNERSHIP MODEL: Personal progress and test results are restricted to the owning student.
     * - UNIQUE IDENTIFIERS: A separate /usernames collection acts as a lock to ensure the 10-char
     *   alphanumeric IDs are unique across the platform.
     * - ADMIN CONTROL: While students can read content, only users verified via the roles_admin
     *   collection can modify global learning materials.
     *
     * DENORMALIZATION FOR AUTHORIZATION:
     * - Subcollections (testAttempts, courseProgress) explicitly repeat the userId within 
     *   document fields to ensure relational integrity between the URL path and the stored data.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is an owner of an existing document before update/delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user has been granted administrative privileges. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description User profile management.
     * @path /users/{userId}
     * @allow (create) if auth.uid matches userId.
     * @deny (read) if trying to access another student's profile.
     * @principle Ownership/Self-Creation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isAdmin();

      /**
       * @description Records of student mock test results.
       * @path /users/{userId}/testAttempts/{testAttemptId}
       * @allow (create) if data.userId matches the path and the user's UID.
       * @principle Path-based Ownership with relational integrity check.
       */
      match /testAttempts/{testAttemptId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      /**
       * @description Overall progress tracking for a specific course.
       * @path /users/{userId}/courseProgress/{courseId}
       * @allow (update) if the owner is updating their own progress percentage.
       * @principle Ownership.
       */
      match /courseProgress/{courseId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }

      /**
       * @description Detailed module-level progress and "Resume Learning" state.
       * @path /users/{userId}/moduleProgress/{moduleId}
       * @allow (read/write) if the student owns the record.
       * @principle Ownership.
       */
      match /moduleProgress/{moduleId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Enforces unique 10-character alphanumeric IDs.
     * @path /usernames/{usernameId}
     * @allow (create) if the username is not already taken.
     * @deny (update) to prevent changing the ID mapping after creation.
     */
    match /usernames/{usernameId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && !exists(/databases/$(database)/documents/usernames/$(usernameId));
      allow update, delete: if isAdmin();
    }

    /**
     * @description Global learning content: Courses, Modules, Lessons, Tests, Questions, Roadmaps, Resources.
     * @path /{collection}/{id}
     * @allow (read) if the user is logged in.
     * @deny (write) if the user is not an administrator.
     * @principle Authenticated Public Read / Admin-Only Write.
     */
    match /courses/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /modules/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /lessons/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /tests/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /questions/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /roadmaps/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /resources/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    /**
     * @description Stores student inquiries from the contact form.
     * @path /contactMessages/{messageId}
     * @allow (create) by any authenticated student.
     * @allow (read) only by platform administrators.
     */
    match /contactMessages/{messageId} {
      allow create: if isSignedIn();
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Registry for administrative UIDs.
     * @path /roles_admin/{adminUid}
     * @allow (read) for checking own status.
     * @deny (write) for all client-side requests.
     */
    match /roles_admin/{adminUid} {
      allow get: if isOwner(adminUid);
      allow list, create, update, delete: if false;
    }
  }
}